# Flask configuration
# IMPORTANT: Change FLASK_ENV to 'production' before deploying!
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key

# Firebase / Firestore
# Get these from your Firebase project settings
FIREBASE_PROJECT_ID=votewiseai
FIREBASE_PRIVATE_KEY=your_private_key_with_newlines_escaped
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@votewiseai.iam.gserviceaccount.com
GOOGLE_CLOUD_PROJECT=votewiseai

# Admin credentials (CHANGE THESE!)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Google APIs (get from Google Cloud Console)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# CORS settings (comma-separated domains for production)
# Use "*" only for development
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Port
PORT=5000

# Firebase Frontend Config (for web login)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=votewiseai.firebaseapp.com
FIREBASE_STORAGE_BUCKET=votewiseai.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id