# ============================================
# VoteWise AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================

# --------------------------------------------
# Flask Configuration
# --------------------------------------------
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=generate-a-strong-random-secret-key

# --------------------------------------------
# Firebase Admin (Service Account)
# Option A: Paste full JSON (recommended for Cloud Run secrets)
# FIREBASE_ADMIN_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","token_uri":"https://oauth2.googleapis.com/token"}
#
# Option B: Set individual fields (for local dev)
# --------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# --------------------------------------------
# Google Cloud
# --------------------------------------------
GOOGLE_CLOUD_PROJECT=your-project-id

# --------------------------------------------
# Google APIs
# --------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --------------------------------------------
# Firebase Frontend Config (client-side)
# Get these from Firebase Console > Project Settings > General
# --------------------------------------------
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# --------------------------------------------
# Admin Credentials
# --------------------------------------------
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=use-a-strong-password

# --------------------------------------------
# CORS (comma-separated origins in production)
# --------------------------------------------
CORS_ORIGINS=*

# --------------------------------------------
# Server
# --------------------------------------------
PORT=8080
